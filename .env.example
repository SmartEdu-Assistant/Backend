APP__NAME=SmartEdu Assistant API
APP__VERSION=0.1.0
APP__DESCRIPTION=API for the SmartEdu Assistant project
APP__API_V1_PREFIX=/api/v1
APP__DEBUG=false
DB__DRIVER=postgresql+asyncpg
DB__ECHO=false
DB__HOST=127.0.0.1
DB__PORT=5432
DB__NAME=smartedu
DB__USER=postgres
DB__PASSWORD=postgres
AUTH__SECRET_KEY=generate_with_openssl_minimum_32_chars
AUTH__ALGORITHM=HS256
AUTH__ACCESS_TOKEN_TTL_MINUTES=15
AUTH__REFRESH_TOKEN_TTL_DAYS=7
AUTH__REFRESH_COOKIE_NAME=refresh_token
AUTH__REFRESH_COOKIE_SECURE=true
AUTH__REFRESH_COOKIE_SAMESITE=lax
AUTH__REFRESH_COOKIE_DOMAIN=
AUTH__REFRESH_COOKIE_PATH=/
RBAC__ADMIN_ROLE_NAME=admin
RBAC__PUBLIC_ROLE_NAME=public
RBAC__TEACHER_ROLE_NAME=teacher
RBAC__ADMIN_EMAIL=admin@example.com
RBAC__ADMIN_PASSWORD=change_me_admin_password
RBAC__ADMIN_FIRST_NAME=System
RBAC__ADMIN_LAST_NAME=Administrator
