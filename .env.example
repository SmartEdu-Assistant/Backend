APP__NAME=SmartEdu Assistant API
APP__VERSION=0.1.0
APP__DESCRIPTION=API for the SmartEdu Assistant project
APP__API_V1_PREFIX=/api/v1
APP__DEBUG=false
BACKEND_IMAGE=docker.io/konstantinks7/smart_edu_assistant@sha256:0b30f1df91bbad24bd875522c4e2533850f08e1c4cb539ecedc299ec70b7a226
DB__DRIVER=postgresql+asyncpg
DB__ECHO=false
DB__HOST=127.0.0.1
DB__PORT=5432
DB__NAME=smartedu
DB__USER=postgres
DB__PASSWORD=postgres
AUTH__SECRET_KEY=generate_with_openssl_minimum_32_chars
AUTH__ALGORITHM=HS256
AUTH__ACCESS_TOKEN_TTL_MINUTES=15
AUTH__REFRESH_TOKEN_TTL_DAYS=7
AUTH__REFRESH_COOKIE_NAME=refresh_token
AUTH__REFRESH_COOKIE_SECURE=true
AUTH__REFRESH_COOKIE_SAMESITE=lax
AUTH__REFRESH_COOKIE_DOMAIN=
AUTH__REFRESH_COOKIE_PATH=/
AUTH__VERIFICATION_TOKEN_TTL_HOURS=24
AUTH__REQUIRE_VERIFIED_ACCOUNT=true
CORS__ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
CORS__ALLOW_CREDENTIALS=true
CORS__ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
CORS__ALLOW_HEADERS=["*"]
RATE_LIMIT__ENABLED=true
RATE_LIMIT__DEFAULT_LIMIT=100/minute
SMTP__ENABLED=false
SMTP__HOST=smtp.example.com
SMTP__PORT=587
SMTP__USERNAME=user@example.com
SMTP__PASSWORD=change_me
SMTP__FROM_EMAIL=noreply@example.com
SMTP__FROM_NAME=SmartEdu Assistant
SMTP__STARTTLS=true
SMTP__SSL_TLS=false
SMTP__VALIDATE_CERTS=true
EMAIL__TEMPLATES_DIR=app/templates/emails
EMAIL__FRONTEND_BASE_URL=http://localhost:3000
RBAC__ADMIN_ROLE_NAME=admin
RBAC__PUBLIC_ROLE_NAME=public
RBAC__TEACHER_ROLE_NAME=teacher
RBAC__ADMIN_EMAIL=admin@example.com
RBAC__ADMIN_PASSWORD=change_me_admin_password
RBAC__ADMIN_FIRST_NAME=System
RBAC__ADMIN_LAST_NAME=Administrator
RBAC__BOOTSTRAP_ON_STARTUP=true
